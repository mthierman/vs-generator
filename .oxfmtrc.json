{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "ignorePatterns": [],
    "printWidth": 100,
    "tabWidth": 4,
    "bracketSameLine": true,
    "quoteProps": "consistent",
    "trailingComma": "all",
    "overrides": [
        {
            "files": ["*.yml", "*.yaml", ".clang-*"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
